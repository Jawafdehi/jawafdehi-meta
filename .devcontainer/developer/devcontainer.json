{
  "name": "Jawafdehi Developer",
  "postCreateCommand": "./.devcontainer/startup.sh",
  "forwardPorts": [40321],
  "customizations": {
    "codespaces": {
      "permissions": {
        "NewNepal-org/*": {
          "permissions": {
            "contents": "write",
            "pull_request": "write",
            "issues": "write"
          }
        }
      }
    },
    "vscode": {
      "extensions": [
        "GitHub.codespaces",
        "GitHub.vscode-pull-request-github",
        "ms-python.python",
        "Github.copilot",
        "mhutchie.git-graph",
        "shd101wyy.markdown-preview-enhanced",
        "zaaack.markdown-editor",
        "mathematic.vscode-pdf",
        "ShahilKumar.docxreader",
        "GrapeCity.gc-excelviewer",
        "mechatroner.rainbow-csv"
      ],
      "settings": {
        "editor.formatOnSave": false,
        "remote.autoForwardPorts": false,
        "javascript.autoClosingTags": false,
		    "python.testing.pytestEnabled": true,
        "window.confirmBeforeClose": true
      }
    }
  },
  "secrets": {
    "NGM_DATABASE_URL": {
      "description": "NGM judicial database URL."
    },
    "JAWAFDEHI_API_BASE_URL": { 
      "description": "Jawafdehi API Base URL."
    },
    "GOOGLE_OAUTH_CLIENT_ID": {
      "description": "Google OAuth Client ID"
    },
    "GOOGLE_OAUTH_CLIENT_SECRET": {
      "description": "Google OAuth Client secret"
    },
    "USER_GOOGLE_EMAIL": {
      "description": "Your google email authorized to access Jawafdehi Shared Drive."
    }
  }
}
