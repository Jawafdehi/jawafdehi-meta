{
  "name": "Default Setup",
  "postCreateCommand": "./.devcontainer/startup.sh",
  "forwardPorts": [40321],
  "customizations": {
    "codespaces": {
      "repositories": {
        "NewNepal-org/*": {
          "permissions": "write-all"
        }
      }
    },
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-python.python",
        "GitHub.codespaces",
        "GitHub.vscode-pull-request-github",
        "Github.copilot",
        "mhutchie.git-graph",
        "shd101wyy.markdown-preview-enhanced",
        "zaaack.markdown-editor"
      ],
      "settings": {
        "editor.formatOnSave": false
      }
    }
  },
  "secrets": {
    "NGM_DATABASE_URL": {
      "description": "NGM judicial database URL."
    },
    "JAWAFDEHI_API_BASE_URL": { 
      "description": "Jawafdehi API Base URL."
    },
    "GOOGLE_OAUTH_CLIENT_ID": {
      "description": "Google OAuth Client ID"
    },
    "GOOGLE_OAUTH_CLIENT_SECRET": {
      "description": "Google OAuth Client secret"
    },
    "USER_GOOGLE_EMAIL": {
      "description": "Your google email authorized to access Jawafdehi Shared Drive."
    }
  }
}
