{
  "servers": {
    "workspace-mcp": {
      "url": "https://google-auth-internal.jawafdehi.org/mcp/",
      "type": "http"
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ],
      "env": {}
    },
    "jawafdehi": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/NewNepal-org/jawafdehi-mcp.git",
        "jawafdehi-mcp"
      ],
      "env": {
        "JAWAFDEHI_API_TOKEN": "${env:JAWAFDEHI_API_TOKEN}"
      },
    }
  }
}